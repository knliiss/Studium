# Studium local defaults
# Copy to .env, or let `infra/scripts/local/start-local.sh` / `start-local.bat` create it automatically.

# ----------------------------------------------------------------------------
# Service ports (host + container)
# ----------------------------------------------------------------------------
GATEWAY_PORT=8080
AUTH_PORT=8081
PROFILE_PORT=8082
FILE_PORT=8083
NOTIFICATION_PORT=8084
EDUCATION_PORT=8085
ASSIGNMENT_PORT=8086
TESTING_PORT=8087
SCHEDULE_PORT=8088
ANALYTICS_PORT=8089
AUDIT_PORT=8090
CONTENT_PORT=8091
FRONTEND_PORT=3000

# Java service replicas (used by infra/scripts/local/start-local.sh and start-local.bat)
AUTH_REPLICAS=1
PROFILE_REPLICAS=1
FILE_REPLICAS=1
NOTIFICATION_REPLICAS=1
GATEWAY_REPLICAS=1
EDUCATION_REPLICAS=1
ASSIGNMENT_REPLICAS=1
TESTING_REPLICAS=1
SCHEDULE_REPLICAS=1
ANALYTICS_REPLICAS=1
AUDIT_REPLICAS=1

# ----------------------------------------------------------------------------
# Infrastructure
# ----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
AUTH_DB_SCHEMA=auth
PROFILE_DB_SCHEMA=profile
FILE_DB_SCHEMA=file
NOTIFICATION_DB_SCHEMA=notification
EDUCATION_DB_SCHEMA=education
ASSIGNMENT_DB_SCHEMA=assignment
TESTING_DB_SCHEMA=testing
SCHEDULE_DB_SCHEMA=schedule
ANALYTICS_DB_SCHEMA=analytics
AUDIT_DB_SCHEMA=audit
CONTENT_DB_SCHEMA=content

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKET_PUBLIC=public
MINIO_BUCKET_PRIVATE=private

# ----------------------------------------------------------------------------
# JWT and shared security
# ----------------------------------------------------------------------------
JWT_ISSUER=dev.knalis.auth-service
JWT_AUDIENCE=dev.knalis.api
JWT_PRIVATE_KEY_PATH=file:/opt/keys/private.pem
JWT_PUBLIC_KEY_PATH=file:/opt/keys/public.pem

# ----------------------------------------------------------------------------
# Cross-service internal authentication
# ----------------------------------------------------------------------------
FILE_INTERNAL_SHARED_SECRET=change-me-file-internal
NOTIFICATION_INTERNAL_SHARED_SECRET=change-me-notification-internal
EDUCATION_INTERNAL_SHARED_SECRET=change-me-education-internal
AUDIT_INTERNAL_SHARED_SECRET=change-me-audit-internal

# ----------------------------------------------------------------------------
# Auth service
# ----------------------------------------------------------------------------
AUTH_MFA_ENABLED=true
# 32-byte key in base64 (example only; replace for real environments)
AUTH_MFA_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
AUTH_OUTBOX_ENABLED=true

# Bootstrap owner user (created once on auth-service startup)
AUTH_OWNER_SEED_ENABLED=true
AUTH_OWNER_USERNAME=owner
AUTH_OWNER_EMAIL=owner@example.com
AUTH_OWNER_PASSWORD=ChangeMe123!

# ----------------------------------------------------------------------------
