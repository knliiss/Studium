GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GATEWAY_RATE_LIMIT_MAX_REQUESTS=120
GATEWAY_RATE_LIMIT_WINDOW=1m
GATEWAY_EDUCATION_SERVICE_BASE_URL=http://localhost:8085
GATEWAY_EDUCATION_SERVICE_CONNECT_TIMEOUT=2s
GATEWAY_EDUCATION_SERVICE_READ_TIMEOUT=5s
